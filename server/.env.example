# MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/ticketing

# Secret used to sign JWTs (change in production)
JWT_SECRET=dev-secret-change-me

# Port the API server listens on
PORT=3001

# Allowed CORS origin (the Vite dev server)
CORS_ORIGIN=http://localhost:8080

# Seeded super-admin credentials (created by `npm run seed`)
SUPER_ADMIN_EMAIL=admin@ticketing.local
SUPER_ADMIN_PASSWORD=admin123
SUPER_ADMIN_NAME=Super Admin
